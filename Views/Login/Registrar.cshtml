@using BusControl.Dto
@model UsuarioRegisterDto


<div class="container">
    <div class="row justify-content-center align-items-center vh-100">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card shadow">
                <div class="card-body p-4">

                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Criar Conta</h2>
                        <p class="text-muted">Preencha os dados para se cadastrar</p>
                    </div>

                    <form asp-action="Registrar" asp-controller="Login" method="Post">

                        

                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" placeholder="Digite seu e-mail">
                        </div>

                        

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Senha</label>
                                <input type="password" class="form-control" placeholder="Digite sua senha">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Confirmar Senha</label>
                                <input type="password" class="form-control" placeholder="Repita a senha">
                            </div>
                        </div>

                        

                       

                        <button type="submit" class="btn btn-success w-100">
                            Criar Conta
                        </button>

                    </form>

                    <hr>

                    <div class="text-center">
                        <span class="text-muted">Já possui uma conta?</span>
                        <a asp-action="Index" asp-controller="Login"     class="text-decoration-none">Entrar</a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>